@model EvidencijaSastanka.DTO.StanarDTO.PrikazStanaraDTO

<div class="container mt-4">
    <h2>Izmena stanara</h2>
    <p class="text-muted">Izmenite podatke o izabranom stanaru.</p>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Izmeni" asp-route-id="@Model.Id" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Ime" class="form-label"></label>
                    <input asp-for="Ime" class="form-control" />
                    <span asp-validation-for="Ime" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Prezime" class="form-label"></label>
                    <input asp-for="Prezime" class="form-control" />
                    <span asp-validation-for="Prezime" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="BrojStana" class="form-label">Broj stana</label>
                    <input asp-for="BrojStana" type="number" min="1" class="form-control" />
                    <span asp-validation-for="BrojStana" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ZgradaId" class="form-label">Zgrada</label>
                    <select asp-for="ZgradaId" asp-items="ViewBag.Zgrade" class="form-select">
                        <option value="">-- Izaberite zgradu --</option>
                    </select>
                    <span asp-validation-for="ZgradaId" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">Sačuvaj izmene</button>
                <a asp-action="Index" class="btn btn-secondary">Nazad</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}