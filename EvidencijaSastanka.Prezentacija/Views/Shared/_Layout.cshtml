<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Evidencija sastanaka stanara</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EvidencijaSastanka.Prezentacija.styles.css" asp-append-version="true" />
</head>

<body>
    @{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
        var prikaziNavigaciju = controller != "Login";
    }

    @if (prikaziNavigaciju)
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand fw-bold" asp-controller="Zgrada" asp-action="Index">
                        Evidencija sastanaka stanara
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Prikaži navigaciju">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Zgrada" asp-action="Index">
                                    Zgrade
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Stanar" asp-action="Index">
                                    Stanari
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Sastanak" asp-action="Index">
                                    Sastanci
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Zapisnik" asp-action="Index">
                                    Zapisnici
                                </a>
                            </li>
                        </ul>

                        <ul class="navbar-nav">
                            @if (Context.Session.GetString("KorisnickoIme") != null)
                            {
                                <li class="nav-item">
                                    <span class="nav-link text-muted">
                                        @Context.Session.GetString("ImePrezime")
                                    </span>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Login" asp-action="Logout">
                                        Odjava
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    @if (prikaziNavigaciju)
    {
        <footer class="border-top footer text-muted mt-4">
            <div class="container">
                &copy; 2026 - Evidencija sastanaka stanara
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>