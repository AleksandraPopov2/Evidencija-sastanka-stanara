@model EvidencijaSastanka.DTO.ZgradaDTO.ZgradaDodavanjeDTO

<h2>Dodavanje zgrade</h2>

<form asp-action="Dodaj" method="post">
    <div class="mb-3">
        <label asp-for="Naziv" class="form-label"></label>
        <input asp-for="Naziv" class="form-control" />
        <span asp-validation-for="Naziv" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Adresa" class="form-label"></label>
        <input asp-for="Adresa" class="form-control" />
        <span asp-validation-for="Adresa" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Sačuvaj</button>
    <a asp-action="Index" class="btn btn-secondary">Nazad</a>
</form>